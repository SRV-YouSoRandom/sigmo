{
  "uid": "sigmo-checklists",
  "title": "Sigmo – Checklist Activity",
  "tags": ["sigmo"],
  "timezone": "Asia/Manila",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "Checklists Started (24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "round(sum(rate(sigmo_checklist_started_total[24h])) * 86400)",
        "legendFormat": "Started"
      }]
    },

    {
      "id": 2,
      "title": "Checklists Completed (24h)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "round(sum(rate(sigmo_checklist_completed_total[24h])) * 86400)",
        "legendFormat": "Completed"
      }]
    },

    {
      "id": 3,
      "title": "Checklists Abandoned (24h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "red", "value": null }] }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "round(sum(rate(sigmo_checklist_abandoned_total[24h])) * 86400)",
        "legendFormat": "Abandoned"
      }]
    },

    {
      "id": 4,
      "title": "Active Sessions Right Now",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "clamp_min(sum(sigmo_active_sessions), 0)",
        "legendFormat": "Active"
      }]
    },

    {
      "id": 5,
      "title": "Checklists Started Today — by Restaurant",
      "description": "Approximate count of checklists started per restaurant in the last 24h",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 7 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient",
        "showUnfilled": true,
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "round(sum by (restaurant_id) (rate(sigmo_checklist_started_total[24h])) * 86400)",
        "legendFormat": "{{restaurant_id}}"
      }]
    },

    {
      "id": 6,
      "title": "Completion Rate — by Restaurant (24h)",
      "description": "Percentage of started checklists that were completed",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 7 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum by (restaurant_id) (rate(sigmo_checklist_completed_total[24h])) / sum by (restaurant_id) (rate(sigmo_checklist_started_total[24h]))",
        "legendFormat": "{{restaurant_id}}"
      }]
    },

    {
      "id": 7,
      "title": "Checklist Activity Over Time — Started vs Completed (per hour)",
      "description": "How many checklists were started and completed over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 11, "w": 24, "h": 9 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "lineWidth": 0,
            "fillOpacity": 80,
            "gradientMode": "none",
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" },
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "round(sum by (restaurant_id) (increase(sigmo_checklist_started_total[1h])))",
          "legendFormat": "Started – {{restaurant_id}}",
          "interval": "1h"
        },
        {
          "datasource": "Prometheus",
          "expr": "round(sum by (restaurant_id) (increase(sigmo_checklist_completed_total[1h])))",
          "legendFormat": "Completed – {{restaurant_id}}",
          "interval": "1h"
        }
      ]
    },

    {
      "id": 8,
      "title": "Avg Checklist Duration — by Type (minutes, 24h)",
      "description": "Average time to complete each checklist type",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 7 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum by (checklist_id) (rate(sigmo_checklist_duration_seconds_sum[24h])) / sum by (checklist_id) (rate(sigmo_checklist_duration_seconds_count[24h])) / 60",
        "legendFormat": "{{checklist_id}}"
      }]
    },

    {
      "id": 9,
      "title": "Issues Reported (24h)",
      "description": "Critical vs Operational issues per restaurant",
      "type": "stat",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 7 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "round(sum by (restaurant_id) (rate(sigmo_issues_reported_total{issue_type=\"critical\"}[24h])) * 86400)",
          "legendFormat": "🔴 Critical – {{restaurant_id}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "round(sum by (restaurant_id) (rate(sigmo_issues_reported_total{issue_type=\"operational\"}[24h])) * 86400)",
          "legendFormat": "🟡 Operational – {{restaurant_id}}"
        }
      ]
    },

    {
      "id": 10,
      "title": "Photos Submitted (24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 27, "w": 8, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "round(sum by (restaurant_id) (rate(sigmo_photos_submitted_total[24h])) * 86400)",
        "legendFormat": "{{restaurant_id}}"
      }]
    },

    {
      "id": 11,
      "title": "Webhook Avg Response Time",
      "type": "stat",
      "gridPos": { "x": 8, "y": 27, "w": 8, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(sigmo_webhook_processing_seconds_sum[5m]) / rate(sigmo_webhook_processing_seconds_count[5m]) * 1000",
        "legendFormat": "Avg latency"
      }]
    },

    {
      "id": 12,
      "title": "Webhook Request Rate",
      "type": "stat",
      "gridPos": { "x": 16, "y": 27, "w": 8, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(sigmo_webhook_processing_seconds_count[5m])",
        "legendFormat": "req/s"
      }]
    }

  ]
}