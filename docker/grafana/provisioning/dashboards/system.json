{
  "uid": "sigmo-system",
  "title": "Sigmo – System Health",
  "tags": ["sigmo", "system"],
  "timezone": "Asia/Manila",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage %",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
        "legendFormat": "CPU %"
      }]
    },
    {
      "id": 2,
      "title": "RAM Used %",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "RAM %"
      }]
    },
    {
      "id": 3,
      "title": "Disk Used %",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"})) * 100",
        "legendFormat": "Disk %"
      }]
    },
    {
      "id": 4,
      "title": "System Uptime",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "time() - node_boot_time_seconds",
        "legendFormat": "Uptime"
      }]
    },
    {
      "id": 5,
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": { "fillOpacity": 15 }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
        "legendFormat": "CPU %"
      }]
    },
    {
      "id": 6,
      "title": "RAM Usage Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used"
        },
        {
          "datasource": "Prometheus",
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "Available"
        }
      ]
    },
    {
      "id": 7,
      "title": "Disk I/O",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(node_disk_read_bytes_total[2m])",
          "legendFormat": "Read"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(node_disk_written_bytes_total[2m])",
          "legendFormat": "Write"
        }
      ]
    },
    {
      "id": 8,
      "title": "Network Traffic",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[2m])",
          "legendFormat": "In – {{device}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[2m])",
          "legendFormat": "Out – {{device}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Disk Space",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10737418240 },
              { "color": "red", "value": 21474836480 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}",
          "legendFormat": "Used"
        },
        {
          "datasource": "Prometheus",
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}",
          "legendFormat": "Free"
        }
      ]
    },
    {
      "id": 10,
      "title": "Load Average (1m / 5m / 15m)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 6 },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "targets": [
        { "datasource": "Prometheus", "expr": "node_load1", "legendFormat": "1m" },
        { "datasource": "Prometheus", "expr": "node_load5", "legendFormat": "5m" },
        { "datasource": "Prometheus", "expr": "node_load15", "legendFormat": "15m" }
      ]
    }
  ]
}